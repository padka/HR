# Base settings shared by docker-compose services.
# Copy to `.env` (or pass via `docker compose --env-file`) and adjust secrets
# before running in production.

ENVIRONMENT=production

# Database configuration (PostgreSQL)
POSTGRES_DB=recruitsmart
POSTGRES_USER=recruitsmart
POSTGRES_PASSWORD=super_secret_db_password
# URL used by the Python apps (async driver is required)
DATABASE_URL=postgresql+asyncpg://recruitsmart:super_secret_db_password@postgres:5432/recruitsmart
# Dedicated migration URL (recommended separate role with DDL rights)
MIGRATIONS_DATABASE_URL=postgresql+asyncpg://recruitsmart:super_secret_db_password@postgres:5432/recruitsmart

# Redis broker/cache (admin UI + bot)
REDIS_URL=redis://redis_notifications:6379/0
NOTIFICATION_BROKER=redis

# Rate limiting (uses Redis DB 1 by default)
# Set to false to disable rate limiting entirely
RATE_LIMIT_ENABLED=true
# Optional: override Redis URL for rate limiting (defaults to REDIS_URL with /1)
# RATE_LIMIT_REDIS_URL=redis://redis_notifications:6379/1
# Set to true if running behind a reverse proxy (nginx, cloudflare, etc.)
# This enables X-Forwarded-For header parsing for accurate client IP detection
TRUST_PROXY_HEADERS=false

# Admin UI authentication
ADMIN_USER=admin
ADMIN_PASSWORD=
WEB_CONCURRENCY=2

# Session secret MUST be at least 32 chars (use `python -c "import secrets; print(secrets.token_hex(32))"`)
SESSION_SECRET=

# Telegram bot
BOT_ENABLED=true
BOT_TOKEN=
BOT_CALLBACK_SECRET=

# Optional logging overrides
LOG_LEVEL=INFO
HTTP_REQUEST_LOG_ENABLED=false
HTTP_SLOW_REQUEST_MS=500

# DB pool baseline
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# hh.ru Integration (via n8n)
HH_SYNC_ENABLED=false
N8N_HH_SYNC_WEBHOOK_URL=https://n8n.recruitsmart.ru/webhook/hh-status-sync
N8N_HH_RESOLVE_WEBHOOK_URL=https://n8n.recruitsmart.ru/webhook/hh-resolve-negotiation
HH_WEBHOOK_SECRET=
HH_INTEGRATION_ENABLED=false
HH_API_BASE_URL=https://api.hh.ru
HH_OAUTH_AUTHORIZE_URL=https://hh.ru/oauth/authorize
HH_CLIENT_ID=
HH_CLIENT_SECRET=
HH_REDIRECT_URI=
HH_USER_AGENT=RecruitSmart/1.0 (engineering@recruitsmart.local)
HH_OAUTH_STATE_TTL_SECONDS=900
HH_WEBHOOK_BASE_URL=

# VK Max Messenger Integration
MAX_BOT_ENABLED=false
MAX_BOT_TOKEN=
MAX_WEBHOOK_URL=https://recruitsmart.ru/max-bot/webhook
MAX_WEBHOOK_SECRET=
# Intro-day handoff to Max sales groups
MAX_INTRO_DAY_HANDOFF_ENABLED=false
# Example:
# {"default":["sales_main_group"],"cities":{"1":["sales_moscow_group"]},"recruiters":{"12":["sales_team_east_group"]}}
MAX_INTRO_DAY_GROUP_ROUTES=
