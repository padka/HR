# Baseline environment template for staging/production-like setups.
# For local development prefer:
#   cp .env.local.example .env.local
# Local helper scripts load `.env.local` if present and otherwise fall back to
# `.env.local.example`. Keep this file free of secrets and use it as the
# canonical variable inventory, not the default local developer profile.

ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/recruitsmart
# Dedicated DB URL for migration role (DDL). In production must be set explicitly.
MIGRATIONS_DATABASE_URL=
DATA_DIR=~/.recruitsmart_admin/data
SESSION_SECRET=change-me-please-32chars-minimum
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-please
# ОБЯЗАТЕЛЬНО задать для production! Если не задано — генерируется случайный пароль.
RECRUITER_DEFAULT_PASSWORD=
ACCESS_TOKEN_TTL_HOURS=12

# Bot / notifications
BOT_ENABLED=false
BOT_INTEGRATION_ENABLED=false
BOT_TOKEN=your-telegram-bot-token
BOT_BACKEND_URL=http://localhost:8000
CRM_PUBLIC_URL=http://localhost:8000
BOT_CALLBACK_SECRET=change-me-please-32chars-minimum
NOTIFICATION_BROKER=memory
REDIS_URL=

# Optional toggles
BOT_AUTOSTART=false
BOT_FAILFAST=true
ENABLE_LEGACY_STATUS_API=false
SIMULATOR_ENABLED=false
# Optional comma-separated host allowlist for CSRF bypass in non-production dev setups.
CSRF_DEV_ALLOWLIST=localhost,127.0.0.1,::1

# Production baseline (recommended)
RATE_LIMIT_ENABLED=true
WEB_CONCURRENCY=2
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
HTTP_REQUEST_LOG_ENABLED=false
HTTP_SLOW_REQUEST_MS=500

# AI (optional)
AI_ENABLED=false
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
AI_TIMEOUT_SECONDS=20
AI_MAX_TOKENS=800
AI_PII_MODE=full

# Interview Script AI
AI_INTERVIEW_SCRIPT_TIMEOUT_SECONDS=30
AI_INTERVIEW_SCRIPT_MAX_TOKENS=1800
AI_INTERVIEW_SCRIPT_CACHE_TTL_HOURS=24
AI_INTERVIEW_SCRIPT_FT_MODEL=
AI_INTERVIEW_SCRIPT_AB_PERCENT=0
AI_INTERVIEW_SCRIPT_FT_MIN_SAMPLES=300
AI_INTERVIEW_SCRIPT_PII_MODE=redacted

# hh.ru Integration (via n8n)
HH_SYNC_ENABLED=false
N8N_HH_SYNC_WEBHOOK_URL=
N8N_HH_RESOLVE_WEBHOOK_URL=
HH_WEBHOOK_SECRET=
HH_INTEGRATION_ENABLED=false
HH_API_BASE_URL=https://api.hh.ru
HH_OAUTH_AUTHORIZE_URL=https://hh.ru/oauth/authorize
HH_CLIENT_ID=
HH_CLIENT_SECRET=
HH_REDIRECT_URI=
HH_USER_AGENT=Attila Recruiting/1.0 (engineering@attila.local)
HH_OAUTH_STATE_TTL_SECONDS=900
HH_WEBHOOK_BASE_URL=

# VK Max Messenger Integration
MAX_BOT_ENABLED=false
MAX_BOT_TOKEN=
MAX_WEBHOOK_URL=
MAX_WEBHOOK_SECRET=
MAX_BOT_LINK_BASE=
MAX_WEBAPP_AUTH_MAX_AGE_SECONDS=900
# Intro-day handoff to Max sales groups
MAX_INTRO_DAY_HANDOFF_ENABLED=false
# JSON mapping example:
# {"default":["sales_main_group"],"cities":{"1":["sales_moscow_group"]},"recruiters":{"12":["sales_team_east_group"]},"city_names":{"алматы":["sales_almaty_group"]}}
MAX_INTRO_DAY_GROUP_ROUTES=
