# Local development configuration (Docker: rs-postgres / rs-redis)
# Copy to .env.local and fill secrets (BOT_TOKEN, strong SESSION_SECRET if needed).

ENVIRONMENT=development

# Postgres in Docker (docker compose postgres service on 5432)
DATABASE_URL=postgresql+asyncpg://recruitsmart:recruitsmart@localhost:5432/recruitsmart

# Redis in Docker (redis_notifications on 6379)
REDIS_URL=redis://localhost:6379/0
NOTIFICATION_BROKER=redis

# Rate limiting (dev: disabled by default, enable for testing)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REDIS_URL=redis://localhost:6379/1
TRUST_PROXY_HEADERS=false

# Admin UI auth (dev-only)
ADMIN_USER=admin
ADMIN_PASSWORD=admin  # dev-only; use a strong password in production
# Optional in local dev; if empty, recruiter creation returns a generated one-time password.
RECRUITER_DEFAULT_PASSWORD=
ACCESS_TOKEN_TTL_HOURS=12

# Skip login in dev (disabled by default; set to true to auto-login as admin)
ALLOW_DEV_AUTOADMIN=false

# Session secret (set to a strong random value if exposing ports)
# Example: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=replace-with-64-hex-session-secret
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=strict

# Bot
BOT_ENABLED=true
BOT_TOKEN=replace-with-bot-token  # obtain from @BotFather
BOT_BACKEND_URL=http://localhost:8000
CRM_PUBLIC_URL=http://localhost:8000
BOT_CALLBACK_SECRET=replace-with-callback-secret  # python -c "import secrets; print(secrets.token_hex(32))"
BOT_AUTOSTART=true

# MAX bot (webhook-based)
MAX_BOT_ENABLED=false
MAX_BOT_TOKEN=replace-with-max-bot-token
MAX_WEBHOOK_URL=
MAX_WEBHOOK_SECRET=replace-with-max-webhook-secret

# Data directory (outside repo by default)
DATA_DIR=~/.recruitsmart_admin/data

# Logging
LOG_LEVEL=INFO
LOG_JSON=false

# AI Copilot / OpenAI
AI_ENABLED=true
AI_PROVIDER=openai
OPENAI_API_KEY=replace-with-openai-key
OPENAI_MODEL=gpt-5-mini
AI_TIMEOUT_SECONDS=20
AI_MAX_TOKENS=800
AI_PII_MODE=full

# Interview Script AI
AI_INTERVIEW_SCRIPT_TIMEOUT_SECONDS=30
AI_INTERVIEW_SCRIPT_MAX_TOKENS=1800
AI_INTERVIEW_SCRIPT_CACHE_TTL_HOURS=24
AI_INTERVIEW_SCRIPT_FT_MODEL=
AI_INTERVIEW_SCRIPT_AB_PERCENT=0
AI_INTERVIEW_SCRIPT_FT_MIN_SAMPLES=300
AI_INTERVIEW_SCRIPT_PII_MODE=redacted

# Local-only tools
SIMULATOR_ENABLED=true
